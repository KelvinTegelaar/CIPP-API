{
  "scriptFile": "../Modules/CippEntrypoints/CippEntrypoints.psm1",
  "entryPoint": "Receive-CippWellKnownTrigger",
  "bindings": [
    {
      "authLevel": "anonymous",
      "type": "httpTrigger",
      "direction": "in",
      "name": "Request",
      "methods": [
        "get"
      ],
      "route": ".well-known/{*rest}"
    },
    {
      "type": "http",
      "direction": "out",
      "name": "Response"
    }
  ]
}
